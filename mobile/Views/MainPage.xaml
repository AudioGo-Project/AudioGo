<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:AudioGo.Models;assembly=Shared"
             x:Class="AudioGo_Mobile.Views.MainPage"
             Shell.NavBarIsVisible="False"
             Title="Trang chủ">

    <ScrollView BackgroundColor="{StaticResource Background}">
        <VerticalStackLayout Spacing="0" Padding="0,0,0,40">

            <!-- ══ Header Section (Hero) ════════════════════════════ -->
            <Grid HeightRequest="240" Margin="0">
                <Image Source="hero_bg.jpg" 
                       Aspect="AspectFill"
                       Opacity="0.8" />
                <BoxView>
                    <BoxView.Background>
                        <RadialGradientBrush Center="0.5,0.5" Radius="1.5">
                            <GradientStop Color="#40f0427c" Offset="0" />
                            <GradientStop Color="{StaticResource Background}" Offset="1" />
                        </RadialGradientBrush>
                    </BoxView.Background>
                </BoxView>

                <!-- Top Bar (Greeting & Profile) -->
                <Grid ColumnDefinitions="*,Auto" 
                      RowDefinitions="Auto"
                      VerticalOptions="Start" 
                      Margin="16,48,16,0">
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="Chào bạn 👋" 
                               Style="{StaticResource SubHeadline}" 
                               HorizontalOptions="Start" />
                        <Label Text="Khám phá qua từng bước chân" 
                               Style="{StaticResource TitleLabel}" 
                               FontSize="22" />
                    </VerticalStackLayout>
                    <Border Grid.Column="1" 
                            WidthRequest="48" 
                            HeightRequest="48"
                            StrokeShape="RoundRectangle 24"
                            StrokeThickness="0">
                        <Image Source="profile_placeholder.png" Aspect="AspectFill" BackgroundColor="{StaticResource Gray200}" />
                    </Border>
                </Grid>

                <!-- Search box over hero -->
                <Border BackgroundColor="{StaticResource Surface}"
                        Style="{StaticResource CardBorder}"
                        Margin="16,0,16,16"
                        VerticalOptions="End"
                        Padding="16,4">
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" Text="🔍" VerticalOptions="Center" FontSize="18" TextColor="{StaticResource TextSecondary}" />
                        <Entry Grid.Column="1" 
                               Placeholder="Tìm kiếm..." 
                               PlaceholderColor="{StaticResource TextTertiary}" 
                               BackgroundColor="Transparent"
                               TextColor="{StaticResource TextPrimary}" />
                    </Grid>
                </Border>
            </Grid>

            <!-- ══ Start GPS Monitoring Banner (Nếu cần) ════════════ -->
            <Border Style="{StaticResource CardBorder}" 
                    Margin="16,16,16,0" 
                    BackgroundColor="{StaticResource PrimaryContainer}">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                    <Label Grid.Row="0" Grid.Column="0" Text="Khởi động audio tour" Style="{StaticResource SectionTitle}" />
                    <Label Grid.Row="1" Grid.Column="0" Text="{Binding StatusMessage}" Style="{StaticResource BodyLabel}" />
                    <Button Grid.RowSpan="2" Grid.Column="1" 
                            Text="Bắt đầu" 
                            Style="{StaticResource PrimaryButton}" 
                            HeightRequest="40" Padding="16,8"
                            Command="{Binding InitCommand}" />
                </Grid>
            </Border>

            <!-- ══ Điểm đến lân cận (Horizontal List of POIs) ═══════ -->
            <VerticalStackLayout Margin="0,24,0,0">
                <Grid ColumnDefinitions="*,Auto" Margin="16,0,16,12">
                    <Label Grid.Column="0" Text="Điểm đến lân cận" Style="{StaticResource SectionTitle}" />
                    <Label Grid.Column="1" Text="Xem tất cả" Style="{StaticResource PrimaryLabel}" />
                </Grid>

                <!-- Loading state -->
                <ActivityIndicator IsRunning="{Binding IsLoading}" 
                                   IsVisible="{Binding IsLoading}" 
                                   Color="{StaticResource Primary}" 
                                   Margin="16" />

                <!-- Binding đến Pois của MainViewModel -->
                <CollectionView ItemsSource="{Binding Pois}" 
                                HorizontalScrollBarVisibility="Never"
                                ItemsLayout="HorizontalList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:POI">
                            <Border Style="{StaticResource CardBorder}" 
                                    WidthRequest="160"
                                    Margin="8,4"
                                    Padding="0">
                                <VerticalStackLayout Spacing="0">
                                    <Image Source="{Binding LogoUrl}" 
                                           HeightRequest="120" 
                                           Aspect="AspectFill" 
                                           BackgroundColor="{StaticResource Gray100}" />
                                    <VerticalStackLayout Padding="12" Spacing="4">
                                        <Label Text="{Binding Title}" 
                                               Style="{StaticResource TitleLabel}" 
                                               FontSize="15" 
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="📍 Cách đây 500m" 
                                               Style="{StaticResource CaptionLabel}" />
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <!-- Header Margin -->
                    <CollectionView.Header>
                        <ContentView WidthRequest="8" />
                    </CollectionView.Header>
                    <CollectionView.Footer>
                        <ContentView WidthRequest="8" />
                    </CollectionView.Footer>
                </CollectionView>
            </VerticalStackLayout>

            <!-- ══ Tour gợi ý (Vertical List) - Dữ liệu Mock ════════ -->
            <VerticalStackLayout Margin="16,24,16,0" Spacing="16">
                <Label Text="Tour khám phá phổ biến" Style="{StaticResource SectionTitle}" />

                <!-- Tour 1 -->
                <Border Style="{StaticResource CardBorder}" Padding="0">
                    <Grid HeightRequest="140">
                        <Image Source="tour_mock1.jpg" Aspect="AspectFill" BackgroundColor="{StaticResource Gray200}" />
                        <BoxView BackgroundColor="#80000000" />
                        <VerticalStackLayout VerticalOptions="End" Padding="16" Spacing="4">
                            <Border Style="{StaticResource ChipBorder}" HorizontalOptions="Start" BackgroundColor="{StaticResource Primary}">
                                <Label Text="★ Bán chạy" TextColor="White" FontSize="11" FontAttributes="Bold" />
                            </Border>
                            <Label Text="Khám Phá Phố Cổ Hà Nội" Style="{StaticResource TitleLabel}" TextColor="White" />
                            <Label Text="2 giờ • 15 điểm phát audio" Style="{StaticResource CaptionLabel}" TextColor="#E0E0E0" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Tour 2 -->
                <Border Style="{StaticResource CardBorder}" Padding="0">
                    <Grid HeightRequest="140">
                        <Image Source="tour_mock2.jpg" Aspect="AspectFill" BackgroundColor="{StaticResource Gray200}" />
                        <BoxView BackgroundColor="#80000000" />
                        <VerticalStackLayout VerticalOptions="End" Padding="16" Spacing="4">
                            <Border Style="{StaticResource ChipBorder}" HorizontalOptions="Start" BackgroundColor="{StaticResource Warning}">
                                <Label Text="🔥 Hấp dẫn" TextColor="White" FontSize="11" FontAttributes="Bold" />
                            </Border>
                            <Label Text="Sài Gòn Xưa và Nay" Style="{StaticResource TitleLabel}" TextColor="White" />
                            <Label Text="3 giờ • 24 điểm phát audio" Style="{StaticResource CaptionLabel}" TextColor="#E0E0E0" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>