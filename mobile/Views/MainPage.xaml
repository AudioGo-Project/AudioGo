<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:AudioGo.Models;assembly=Shared"
             x:Class="AudioGo_Mobile.Views.MainPage"
             Shell.NavBarIsVisible="False"
             Title="Trang chủ">

    <ScrollView BackgroundColor="{StaticResource Background}">
        <VerticalStackLayout Spacing="0" Padding="0,0,0,40">

            <!-- ══ Hero Header — ảnh Vĩnh Khánh + overlay ════════════════ -->
            <Grid HeightRequest="260" Margin="0">
                <!-- Ảnh nền thực tế (đã thêm vào Resources/Images/) -->
                <Image Source="hero_bg.jpg"
                       Aspect="AspectFill" />

                <!-- Overlay đen 35% — làm nổi text trắng -->
                <BoxView BackgroundColor="#59000000" />

                <!-- Gradient từ dưới lên -->
                <BoxView>
                    <BoxView.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="Transparent" Offset="0.3" />
                            <GradientStop Color="#CF000000" Offset="1.0" />
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>

                <!-- Top bar -->
                <Grid ColumnDefinitions="*,Auto"
                      VerticalOptions="Start"
                      Margin="20,52,20,0">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="📍 Khu phố Vĩnh Khánh"
                               TextColor="#E0E0E0"
                               FontSize="13" />
                        <Label Text="Khám phá Vĩnh Khánh"
                               TextColor="White"
                               FontSize="22"
                               FontAttributes="Bold"
                               FontFamily="InterBold" />
                    </VerticalStackLayout>
                    <!-- QR scan button -->
                    <Border Grid.Column="1"
                            BackgroundColor="#59FFFFFF"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="0"
                            Padding="10"
                            WidthRequest="44"
                            HeightRequest="44"
                            VerticalOptions="Start">
                        <Label Text="⊡" FontSize="20" TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding QrScanCommand}" />
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

                <!-- Search box nổi trên bottom -->
                <Border BackgroundColor="{StaticResource Surface}"
                        Style="{StaticResource CardBorder}"
                        Margin="16,0,16,16"
                        VerticalOptions="End"
                        Padding="16,4">
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" Text="🔍" VerticalOptions="Center"
                               FontSize="18" TextColor="{StaticResource TextSecondary}" />
                        <Entry Grid.Column="1"
                               Placeholder="Tìm điểm ăn, quán, địa điểm..."
                               PlaceholderColor="{StaticResource TextTertiary}"
                               BackgroundColor="Transparent"
                               TextColor="{StaticResource TextPrimary}"
                               ReturnCommand="{Binding SearchCommand}" />
                    </Grid>
                </Border>
            </Grid>

            <!-- ══ Voice Toggle — Giọng Nữ / Giọng Nam ══════════════════ -->
            <Grid ColumnDefinitions="*,*" Margin="16,16,16,0" ColumnSpacing="8">
                <!-- Giọng Nữ -->
                <Border Grid.Column="0"
                        BackgroundColor="{StaticResource Primary}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="0"
                        Padding="0,10">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                        <Label Text="♀" FontSize="18" TextColor="White" HorizontalOptions="Center"/>
                        <Label Text="Giọng Nữ" FontSize="13" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetVoiceCommand}" CommandParameter="female"/>
                    </Border.GestureRecognizers>
                </Border>
                <!-- Giọng Nam -->
                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="1.5"
                        Stroke="{StaticResource Gray200}"
                        Padding="0,10">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                        <Label Text="♂" FontSize="18" TextColor="{StaticResource TextSecondary}"
                               HorizontalOptions="Center"/>
                        <Label Text="Giọng Nam" FontSize="13"
                               TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetVoiceCommand}" CommandParameter="male"/>
                    </Border.GestureRecognizers>
                </Border>
            </Grid>

            <!-- ══ Category chips — Chủ yếu đồ ăn ════════════════════════ -->
            <ScrollView Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never"
                        Margin="0,16,0,0">
                <HorizontalStackLayout Spacing="8" Padding="16,0">
                    <Border Style="{StaticResource ChipBorder}" BackgroundColor="{StaticResource Primary}">
                        <Label Text="🍽️ Tất cả" TextColor="White" FontAttributes="Bold" />
                    </Border>
                    <Border Style="{StaticResource ChipBorder}" BackgroundColor="{StaticResource Surface}">
                        <Label Text="🦐 Hải sản" TextColor="{StaticResource TextSecondary}" />
                    </Border>
                    <Border Style="{StaticResource ChipBorder}" BackgroundColor="{StaticResource Surface}">
                        <Label Text="🍜 Bún bò" TextColor="{StaticResource TextSecondary}" />
                    </Border>
                    <Border Style="{StaticResource ChipBorder}" BackgroundColor="{StaticResource Surface}">
                        <Label Text="🍢 Ốc" TextColor="{StaticResource TextSecondary}" />
                    </Border>
                    <Border Style="{StaticResource ChipBorder}" BackgroundColor="{StaticResource Surface}">
                        <Label Text="☕ Quán cà phê" TextColor="{StaticResource TextSecondary}" />
                    </Border>
                    <Border Style="{StaticResource ChipBorder}" BackgroundColor="{StaticResource Surface}">
                        <Label Text="🏛️ Di tích" TextColor="{StaticResource TextSecondary}" />
                    </Border>
                </HorizontalStackLayout>
            </ScrollView>

            <!-- ══ Status Banner ═══════════════════════════════════════════ -->
            <Border Style="{StaticResource CardBorder}"
                    Margin="16,16,16,0"
                    BackgroundColor="{StaticResource PrimaryContainer}">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                    <Label Grid.Row="0" Grid.Column="0"
                           Text="Bắt đầu khám phá Vĩnh Khánh"
                           Style="{StaticResource SectionTitle}" />
                    <Label Grid.Row="1" Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Style="{StaticResource BodyLabel}" />
                    <Button Grid.RowSpan="2" Grid.Column="1"
                            Text="Bắt đầu"
                            Style="{StaticResource PrimaryButton}"
                            HeightRequest="40" Padding="16,8"
                            Command="{Binding InitCommand}" />
                </Grid>
            </Border>

            <!-- ══ Điểm đến lân cận ════════════════════════════════════════ -->
            <VerticalStackLayout Margin="0,24,0,0">
                <Grid ColumnDefinitions="*,Auto" Margin="16,0,16,12">
                    <Label Grid.Column="0" Text="Điểm nổi bật gần bạn"
                           Style="{StaticResource SectionTitle}" />
                    <Label Grid.Column="1" Text="Xem tất cả"
                           Style="{StaticResource PrimaryLabel}" />
                </Grid>

                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="{StaticResource Primary}"
                                   Margin="16" />

                <CollectionView ItemsSource="{Binding Pois}"
                                HorizontalScrollBarVisibility="Never"
                                ItemsLayout="HorizontalList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardBorder}"
                                    WidthRequest="160"
                                    Margin="8,4"
                                    Padding="0">
                                <VerticalStackLayout Spacing="0">
                                    <Image Source="{Binding LogoUrl}"
                                           HeightRequest="110"
                                           Aspect="AspectFill"
                                           BackgroundColor="{StaticResource Gray100}" />
                                    <VerticalStackLayout Padding="10" Spacing="4">
                                        <!-- Category badge -->
                                        <Border BackgroundColor="{StaticResource PrimaryContainer}"
                                                StrokeShape="RoundRectangle 6"
                                                StrokeThickness="0"
                                                Padding="6,2"
                                                HorizontalOptions="Start"
                                                IsVisible="{Binding Categories.Count, Converter={StaticResource IntToBoolConverter}}">
                                            <Label Text="{Binding Categories[0]}"
                                                   TextColor="{StaticResource Primary}"
                                                   FontSize="10" FontAttributes="Bold" />
                                        </Border>
                                        <Label Text="{Binding Title}"
                                               Style="{StaticResource TitleLabel}"
                                               FontSize="14"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="📍 Khu phố Vĩnh Khánh"
                                               Style="{StaticResource CaptionLabel}" />
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.Header>
                        <ContentView WidthRequest="8" />
                    </CollectionView.Header>
                    <CollectionView.Footer>
                        <ContentView WidthRequest="8" />
                    </CollectionView.Footer>
                </CollectionView>
            </VerticalStackLayout>

            <!-- ══ Tour nổi bật ════════════════════════════════════════════ -->
            <VerticalStackLayout Margin="16,24,16,0" Spacing="16">
                <Label Text="Tour ẩm thực phổ biến" Style="{StaticResource SectionTitle}" />

                <Border Style="{StaticResource CardBorder}" Padding="0">
                    <Grid HeightRequest="150">
                        <Image Source="tour_mock1.jpg" Aspect="AspectFill"
                               BackgroundColor="{StaticResource Gray200}" />
                        <BoxView BackgroundColor="#80000000" />
                        <VerticalStackLayout VerticalOptions="End" Padding="16" Spacing="4">
                            <Border Style="{StaticResource ChipBorder}"
                                    HorizontalOptions="Start"
                                    BackgroundColor="{StaticResource Primary}">
                                <Label Text="🦐 Hải sản" TextColor="White"
                                       FontSize="11" FontAttributes="Bold" />
                            </Border>
                            <Label Text="Tour Vĩnh Khánh Ẩm Thực"
                                   Style="{StaticResource TitleLabel}"
                                   TextColor="White" />
                            <Label Text="1.5 giờ • 8 điểm phát audio"
                                   Style="{StaticResource CaptionLabel}"
                                   TextColor="#E0E0E0" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardBorder}" Padding="0">
                    <Grid HeightRequest="150">
                        <Image Source="tour_mock2.jpg" Aspect="AspectFill"
                               BackgroundColor="{StaticResource Gray200}" />
                        <BoxView BackgroundColor="#80000000" />
                        <VerticalStackLayout VerticalOptions="End" Padding="16" Spacing="4">
                            <Border Style="{StaticResource ChipBorder}"
                                    HorizontalOptions="Start"
                                    BackgroundColor="{StaticResource Warning}">
                                <Label Text="🏛️ Lịch sử" TextColor="White"
                                       FontSize="11" FontAttributes="Bold" />
                            </Border>
                            <Label Text="Vĩnh Khánh — Ký Ức Phố Cảng"
                                   Style="{StaticResource TitleLabel}"
                                   TextColor="White" />
                            <Label Text="2 giờ • 12 điểm phát audio"
                                   Style="{StaticResource CaptionLabel}"
                                   TextColor="#E0E0E0" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>