<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AudioGo_Mobile.Views.MainPage"
             Shell.NavBarIsVisible="False"
             Title="Trang chủ">

    <ScrollView BackgroundColor="{StaticResource Background}">
        <VerticalStackLayout Spacing="0" Padding="0,0,0,40">

            <!-- ══ Hero Header — ảnh Vĩnh Khánh + overlay ════════════════ -->
            <Grid HeightRequest="240" Margin="0">
                <!-- Ảnh nền thực tế (đã thêm vào Resources/Images/) -->
                <Image Source="hero_bg.jpg" Aspect="AspectFill" />

                <!-- Overlay đen 35% — làm nổi text trắng -->
                <BoxView BackgroundColor="#59000000" />

                <!-- Gradient từ dưới lên -->
                <BoxView>
                    <BoxView.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="Transparent" Offset="0.3" />
                            <GradientStop Color="#CF000000" Offset="1.0" />
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>

                <!-- Top bar: địa điểm + nút QR -->
                <Grid ColumnDefinitions="*,Auto"
                      VerticalOptions="Start"
                      Margin="20,52,20,0">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="📍 Khu phố Vĩnh Khánh"
                               TextColor="#E0E0E0" FontSize="13" />
                        <Label Text="Khám phá Vĩnh Khánh"
                               TextColor="White" FontSize="22"
                               FontAttributes="Bold" FontFamily="InterBold" />
                    </VerticalStackLayout>
                    <!-- QR scan button -->
                    <Border Grid.Column="1"
                            BackgroundColor="#59FFFFFF"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="0"
                            Padding="10"
                            WidthRequest="44" HeightRequest="44"
                            VerticalOptions="Start">
                        <Label Text="⊡" FontSize="20" TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding QrScanCommand}" />
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

                <!-- Tagline ở dưới hero — không có search bar (đã có tab Search) -->
                <Label Text="Scan QR hoặc chọn tour để bắt đầu 🎧"
                       TextColor="#CCE0E0E0" FontSize="13"
                       VerticalOptions="End"
                       Margin="20,0,20,16" />
            </Grid>

            <!-- ══ Voice Toggle — nhỏ gọn hơn ══════════════════════════════ -->
            <Grid ColumnDefinitions="*,*" Margin="16,14,16,0" ColumnSpacing="8">
                <!-- Giọng Nữ -->
                <Border Grid.Column="0"
                        BackgroundColor="{StaticResource Primary}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="0"
                        Padding="0,6">
                    <Grid ColumnDefinitions="Auto,*" Padding="12,0" ColumnSpacing="6">
                        <Label Grid.Column="0" Text="♀" FontSize="16" TextColor="White"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Giọng Nữ" FontSize="13"
                               FontAttributes="Bold" TextColor="White"
                               VerticalOptions="Center"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetVoiceCommand}" CommandParameter="female"/>
                    </Border.GestureRecognizers>
                </Border>
                <!-- Giọng Nam -->
                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="1.5"
                        Stroke="{StaticResource Gray200}"
                        Padding="0,6">
                    <Grid ColumnDefinitions="Auto,*" Padding="12,0" ColumnSpacing="6">
                        <Label Grid.Column="0" Text="♂" FontSize="16"
                               TextColor="{StaticResource TextSecondary}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Giọng Nam" FontSize="13"
                               TextColor="{StaticResource TextSecondary}"
                               VerticalOptions="Center"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetVoiceCommand}" CommandParameter="male"/>
                    </Border.GestureRecognizers>
                </Border>
            </Grid>

            <!-- ══ Category chips — Chủ yếu đồ ăn ════════════════════════ -->
            <ScrollView Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never"
                        Margin="0,14,0,0">
                <HorizontalStackLayout Spacing="8" Padding="16,0">
                    <Border Style="{StaticResource ChipBorder}" BackgroundColor="{StaticResource Primary}">
                        <Label Text="🍽️ Tất cả" TextColor="White" FontAttributes="Bold" />
                    </Border>
                    <Border Style="{StaticResource ChipBorder}" BackgroundColor="{StaticResource Surface}">
                        <Label Text="🦐 Hải sản" TextColor="{StaticResource TextSecondary}" />
                    </Border>
                    <Border Style="{StaticResource ChipBorder}" BackgroundColor="{StaticResource Surface}">
                        <Label Text="🍜 Bún bò" TextColor="{StaticResource TextSecondary}" />
                    </Border>
                    <Border Style="{StaticResource ChipBorder}" BackgroundColor="{StaticResource Surface}">
                        <Label Text="🍢 Ốc" TextColor="{StaticResource TextSecondary}" />
                    </Border>
                    <Border Style="{StaticResource ChipBorder}" BackgroundColor="{StaticResource Surface}">
                        <Label Text="☕ Cà phê" TextColor="{StaticResource TextSecondary}" />
                    </Border>
                    <Border Style="{StaticResource ChipBorder}" BackgroundColor="{StaticResource Surface}">
                        <Label Text="🏛️ Di tích" TextColor="{StaticResource TextSecondary}" />
                    </Border>
                </HorizontalStackLayout>
            </ScrollView>

            <!-- ══ Điểm đến lân cận ════════════════════════════════════════ -->
            <VerticalStackLayout Margin="0,20,0,0">
                <Grid ColumnDefinitions="*,Auto" Margin="16,0,16,12">
                    <Label Grid.Column="0" Text="Điểm nổi bật gần bạn"
                           Style="{StaticResource SectionTitle}" />
                    <Label Grid.Column="1" Text="Xem tất cả"
                           Style="{StaticResource PrimaryLabel}" />
                </Grid>

                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="{StaticResource Primary}"
                                   Margin="16" />

                <CollectionView ItemsSource="{Binding Pois}"
                                HorizontalScrollBarVisibility="Never"
                                ItemsLayout="HorizontalList">
                    <CollectionView.Header>
                        <ContentView WidthRequest="8" />
                    </CollectionView.Header>
                    <CollectionView.Footer>
                        <ContentView WidthRequest="8" />
                    </CollectionView.Footer>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardBorder}"
                                    WidthRequest="160" Margin="8,4" Padding="0">
                                <VerticalStackLayout Spacing="0">
                                    <Image Source="{Binding LogoUrl}"
                                           HeightRequest="110" Aspect="AspectFill"
                                           BackgroundColor="{StaticResource Gray100}" />
                                    <VerticalStackLayout Padding="10" Spacing="4">
                                        <Border BackgroundColor="{StaticResource PrimaryContainer}"
                                                StrokeShape="RoundRectangle 6"
                                                StrokeThickness="0" Padding="6,2"
                                                HorizontalOptions="Start">
                                            <Label Text="{Binding Categories[0]}"
                                                   TextColor="{StaticResource Primary}"
                                                   FontSize="10" FontAttributes="Bold" />
                                        </Border>
                                        <Label Text="{Binding Title}"
                                               Style="{StaticResource TitleLabel}"
                                               FontSize="14"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="📍 Vĩnh Khánh"
                                               Style="{StaticResource CaptionLabel}" />
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- ══ Tour nổi bật — mỗi card có nút Bắt đầu ════════════════ -->
            <VerticalStackLayout Margin="16,20,16,0" Spacing="14">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="Chọn tour"
                           Style="{StaticResource SectionTitle}" />
                    <Label Grid.Column="1" Text="Xem tất cả"
                           Style="{StaticResource PrimaryLabel}" />
                </Grid>

                <!-- Tour card 1 -->
                <Border Style="{StaticResource CardBorder}" Padding="0">
                    <VerticalStackLayout>
                        <Grid HeightRequest="140">
                            <Image Source="tour_mock1.jpg" Aspect="AspectFill"
                                   BackgroundColor="{StaticResource Gray200}" />
                            <BoxView BackgroundColor="#80000000" />
                            <VerticalStackLayout VerticalOptions="End" Padding="14,10" Spacing="4">
                                <Border Style="{StaticResource ChipBorder}"
                                        HorizontalOptions="Start"
                                        BackgroundColor="{StaticResource Primary}">
                                    <Label Text="🦐 Hải sản" TextColor="White"
                                           FontSize="11" FontAttributes="Bold" />
                                </Border>
                                <Label Text="Tour Vĩnh Khánh Ẩm Thực"
                                       TextColor="White" FontAttributes="Bold" FontSize="15"/>
                                <Label Text="1.5 giờ  •  8 điểm phát audio"
                                       TextColor="#E0E0E0" FontSize="12" />
                            </VerticalStackLayout>
                        </Grid>
                        <!-- Nút Bắt đầu -->
                        <Border BackgroundColor="{StaticResource Surface}"
                                Padding="14,10">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="Miễn phí • 8 điểm"
                                       TextColor="{StaticResource TextSecondary}"
                                       VerticalOptions="Center" FontSize="13"/>
                                <Border Grid.Column="1"
                                        BackgroundColor="{StaticResource Primary}"
                                        StrokeShape="RoundRectangle 20"
                                        StrokeThickness="0"
                                        Padding="18,8">
                                    <Label Text="▶ Bắt đầu" TextColor="White"
                                           FontAttributes="Bold" FontSize="13"/>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding StartTourCommand}"
                                                              CommandParameter="tour-1"/>
                                    </Border.GestureRecognizers>
                                </Border>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!-- Tour card 2 -->
                <Border Style="{StaticResource CardBorder}" Padding="0">
                    <VerticalStackLayout>
                        <Grid HeightRequest="140">
                            <Image Source="tour_mock2.jpg" Aspect="AspectFill"
                                   BackgroundColor="{StaticResource Gray200}" />
                            <BoxView BackgroundColor="#80000000" />
                            <VerticalStackLayout VerticalOptions="End" Padding="14,10" Spacing="4">
                                <Border Style="{StaticResource ChipBorder}"
                                        HorizontalOptions="Start"
                                        BackgroundColor="{StaticResource Warning}">
                                    <Label Text="🏛️ Lịch sử" TextColor="White"
                                           FontSize="11" FontAttributes="Bold" />
                                </Border>
                                <Label Text="Vĩnh Khánh — Ký Ức Phố Cảng"
                                       TextColor="White" FontAttributes="Bold" FontSize="15"/>
                                <Label Text="2 giờ  •  12 điểm phát audio"
                                       TextColor="#E0E0E0" FontSize="12" />
                            </VerticalStackLayout>
                        </Grid>
                        <!-- Nút Bắt đầu -->
                        <Border BackgroundColor="{StaticResource Surface}"
                                Padding="14,10">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="Miễn phí • 12 điểm"
                                       TextColor="{StaticResource TextSecondary}"
                                       VerticalOptions="Center" FontSize="13"/>
                                <Border Grid.Column="1"
                                        BackgroundColor="{StaticResource Primary}"
                                        StrokeShape="RoundRectangle 20"
                                        StrokeThickness="0"
                                        Padding="18,8">
                                    <Label Text="▶ Bắt đầu" TextColor="White"
                                           FontAttributes="Bold" FontSize="13"/>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding StartTourCommand}"
                                                              CommandParameter="tour-2"/>
                                    </Border.GestureRecognizers>
                                </Border>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- ══ Tour của Tôi — section mới ════════════════════════════════ -->
            <VerticalStackLayout Margin="16,24,16,0" Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="Tour của bạn"
                           Style="{StaticResource SectionTitle}" />
                    <!-- Nút tạo tour mới -->
                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource Primary}"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="0"
                            Padding="12,6">
                        <Label Text="+ Tạo mới" TextColor="White"
                               FontSize="13" FontAttributes="Bold"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CreateTourCommand}"/>
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

                <!-- Empty state khi chưa có tour tự tạo -->
                <Border Style="{StaticResource CardBorder}"
                        BackgroundColor="{StaticResource Surface}"
                        Padding="20,24">
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="🗺️" FontSize="36" HorizontalOptions="Center"/>
                        <Label Text="Bạn chưa tạo tour nào"
                               Style="{StaticResource TitleLabel}"
                               HorizontalOptions="Center"/>
                        <Label Text="Tự thiết kế hành trình ẩm thực Vĩnh Khánh theo cách của bạn"
                               Style="{StaticResource BodyLabel}"
                               HorizontalTextAlignment="Center"
                               HorizontalOptions="Center"/>
                        <Border BackgroundColor="{StaticResource Primary}"
                                StrokeShape="RoundRectangle 20"
                                StrokeThickness="0"
                                Padding="24,10"
                                HorizontalOptions="Center"
                                Margin="0,4,0,0">
                            <Label Text="Tạo tour đầu tiên →" TextColor="White"
                                   FontAttributes="Bold" FontSize="14"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CreateTourCommand}"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>