<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             xmlns:vm="clr-namespace:AudioGo.ViewModels"
             x:Class="AudioGo_Mobile.Views.MapPage"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Background}"
             Title="{Binding MapTitle}">

    <Grid>

        <!-- ── Map Full Screen ── -->
        <Grid>
            <maps:Map x:Name="MainMap"
                      IsShowingUser="True"
                      MapType="Street"
                      IsScrollEnabled="True"
                      IsZoomEnabled="True"/>


            <!-- ── Loading overlay ── -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>

            <!-- ── POI Banner (Anchored to center above pin) ── -->
            <Border x:Name="PoiBanner"
                    BackgroundColor="{StaticResource Surface}"
                    StrokeShape="RoundRectangle 16"
                    StrokeThickness="0"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Margin="0,0,0,160"
                    WidthRequest="280"
                    Opacity="0"
                    IsVisible="False">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.15"/>
                </Border.Shadow>
                <VerticalStackLayout Padding="0" Spacing="0">
                    <!-- Top section: Logo + Title/Tags -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" Padding="14,14,14,10">
                        <!-- POI Logo -->
                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource PrimaryLight}"
                                StrokeShape="RoundRectangle 12"
                                StrokeThickness="0"
                                WidthRequest="56" HeightRequest="56"
                                VerticalOptions="Center">
                             <Grid>
                                 <Label Text="&#xe0c8;" FontFamily="MaterialIcons" FontSize="28" TextColor="{StaticResource Primary}"
                                        HorizontalOptions="Center" VerticalOptions="Center"/>
                                 <Image x:Name="BannerLogo" Aspect="AspectFill"/>
                             </Grid>
                        </Border>

                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                            <!-- Title -->
                            <Label x:Name="BannerTitle" FontAttributes="Bold" FontSize="15"
                                   MaxLines="2" LineBreakMode="TailTruncation" />

                            <!-- Tags -->
                            <FlexLayout JustifyContent="Start" Wrap="Wrap">
                                <!-- Ngôn ngữ -->
                                <Border Margin="0,0,6,0" StrokeShape="RoundRectangle 4" BackgroundColor="{StaticResource PrimaryLight}" StrokeThickness="0" Padding="4,2">
                                    <Label x:Name="BannerLang" FontSize="10" TextColor="{StaticResource Primary}" FontAttributes="Bold" />
                                </Border>
                                <!-- Thời gian di chuyển -->
                                <Border Margin="0,0,6,0" StrokeShape="RoundRectangle 4" BackgroundColor="{StaticResource Gray100}" StrokeThickness="0" Padding="4,2">
                                    <Label x:Name="BannerTime" FontSize="10" TextColor="{StaticResource Gray500}" />
                                </Border>
                            </FlexLayout>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" Color="{StaticResource Gray200}" Margin="14,0"/>

                    <!-- 3 Buttons Row -->
                    <Grid ColumnDefinitions="*,*,*" Padding="10,8,10,10" ColumnSpacing="6">
                        <!-- Play -->
                        <Border Grid.Column="0" BackgroundColor="{StaticResource PrimaryLight}"
                                StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="0,8">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                                <Label Text="&#xe039;" FontFamily="MaterialIcons" FontSize="20" TextColor="{StaticResource Primary}" HorizontalOptions="Center"/>
                                <Label Text="{Binding MapListenLabel}" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Primary}" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPoiBannerPlayClicked"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <!-- Detail -->
                        <Border Grid.Column="1" BackgroundColor="#FFC107"
                                StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="0,8">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                                <Label Text="&#xe8f4;" FontFamily="MaterialIcons" FontSize="20" TextColor="#333333" HorizontalOptions="Center"/>
                                <Label Text="{Binding MapDetailsLabel}" FontSize="11" FontAttributes="Bold" TextColor="#333333" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPoiBannerDetailClicked"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <!-- Navigate -->
                        <Border Grid.Column="2" BackgroundColor="{StaticResource Primary}"
                                StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="0,8">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                                <Label Text="&#xe52f;" FontFamily="MaterialIcons" FontSize="20" TextColor="White" HorizontalOptions="Center"/>
                                <Label Text="{Binding MapDirectionsLabel}" FontSize="11" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBannerDirectionsTapped"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>



        </Grid>

        <!-- ── Bottom: Mini Player ── -->
        <Grid x:Name="MiniPlayerGrid" VerticalOptions="End" Margin="0,0,0,16">
            <Border Style="{StaticResource MiniPlayerBar}"
                    Margin="12,0,12,8" Padding="12,10"
                    IsVisible="{Binding HasActivePoi}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenPoiDetailCommand}"
                                          CommandParameter="{Binding ActivePoi}"/>
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                    <Border Grid.Column="0"
                            BackgroundColor="{StaticResource PrimaryLight}"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="0"
                            WidthRequest="44" HeightRequest="44">
                        <Grid>
                            <Label Text="&#xe310;" FontFamily="MaterialIcons" FontSize="24"
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Image Source="{Binding ActivePoi.LogoUrl}" Aspect="AspectFill"/>
                        </Grid>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <Label Text="{Binding ActivePoi.Title}"
                               Style="{StaticResource SectionTitle}" FontSize="14"
                               LineBreakMode="TailTruncation"/>
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="&#xe310;" FontFamily="MaterialIcons" FontSize="11"
                                   TextColor="{StaticResource Primary}" VerticalOptions="Center"/>
                            <Label Text="{Binding MiniPlayerNowPlaying}" Style="{StaticResource CaptionLabel}"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                    <Border Grid.Column="2"
                            BackgroundColor="{StaticResource Primary}"
                            StrokeShape="RoundRectangle 18"
                            StrokeThickness="0"
                            WidthRequest="36" HeightRequest="36">
                        <Label Text="{Binding MiniPlayerPlayIcon}" FontFamily="MaterialIcons"
                               FontSize="20" TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMiniPlayClicked"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <Border Grid.Column="3"
                            BackgroundColor="{StaticResource Gray100}"
                            StrokeShape="RoundRectangle 18"
                            StrokeThickness="0"
                            WidthRequest="36" HeightRequest="36">
                        <Label Text="&#xe5cd;" FontFamily="MaterialIcons" FontSize="20"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMiniPlayerCloseTapped"/>
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
