<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             xmlns:vm="clr-namespace:AudioGo.ViewModels"
             x:Class="AudioGo_Mobile.Views.MapPage"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Background}"
             Title="Bản đồ">

    <Grid>

        <!-- ── Map Full Screen ── -->
        <Grid>
            <maps:Map x:Name="MainMap"
                      IsShowingUser="True"
                      MapType="Street"
                      IsScrollEnabled="True"
                      IsZoomEnabled="True"/>


            <!-- ── Loading overlay ── -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>

            <!-- ── POI Banner (Anchored to center above pin) ── -->
            <Border x:Name="PoiBanner"
                    BackgroundColor="{StaticResource Surface}"
                    StrokeShape="RoundRectangle 16"
                    StrokeThickness="0"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Margin="0,0,0,160"
                    WidthRequest="220"
                    Opacity="0"
                    IsVisible="False">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.15"/>
                </Border.Shadow>
                <VerticalStackLayout Padding="14" Spacing="10">
                    <!-- Title -->
                    <Label x:Name="BannerTitle" FontAttributes="Bold" FontSize="14"
                           HorizontalTextAlignment="Center" MaxLines="2" LineBreakMode="TailTruncation" />

                    <!-- Tags -->
                    <FlexLayout JustifyContent="Center" Wrap="Wrap" HorizontalOptions="Center" VerticalOptions="Start" DefaultMargin="0,0,4,4">
                        <!-- Ngôn ngữ -->
                        <Border StrokeShape="RoundRectangle 4" BackgroundColor="{StaticResource PrimaryLight}" StrokeThickness="0" Padding="4,2">
                            <Label x:Name="BannerLang" FontSize="10" TextColor="{StaticResource Primary}" FontAttributes="Bold" />
                        </Border>
                        <!-- Thời gian di chuyển -->
                        <Border StrokeShape="RoundRectangle 4" BackgroundColor="{StaticResource Gray100}" StrokeThickness="0" Padding="4,2">
                            <Label x:Name="BannerTime" FontSize="10" TextColor="{StaticResource Gray500}" />
                        </Border>
                    </FlexLayout>

                    <!-- 3 Buttons Row -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <!-- Play -->
                        <Border Grid.Column="0" BackgroundColor="{StaticResource PrimaryLight}"
                                StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="0,10">
                            <Label Text="&#xe039;" FontFamily="MaterialIcons" FontSize="20" TextColor="{StaticResource Primary}" HorizontalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPoiBannerPlayClicked"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <!-- Detail -->
                        <Border Grid.Column="1" BackgroundColor="{StaticResource PrimaryLight}"
                                StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="0,10">
                            <Label Text="&#xe8f4;" FontFamily="MaterialIcons" FontSize="20" TextColor="{StaticResource Primary}" HorizontalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPoiBannerDetailClicked"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <!-- Navigate -->
                        <Border Grid.Column="2" BackgroundColor="{StaticResource PrimaryLight}"
                                StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="0,10">
                            <Label Text="&#xe52f;" FontFamily="MaterialIcons" FontSize="20" TextColor="{StaticResource Primary}" HorizontalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBannerDirectionsTapped"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>



        </Grid>

        <!-- ── Bottom: Mini Player ── -->
        <Grid x:Name="MiniPlayerGrid" VerticalOptions="End" Margin="0,0,0,16">
            <Border Style="{StaticResource MiniPlayerBar}"
                    Margin="12,0,12,8" Padding="12,10"
                    IsVisible="{Binding HasActivePoi}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenPoiDetailCommand}"
                                          CommandParameter="{Binding ActivePoi}"/>
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                    <Border Grid.Column="0"
                            BackgroundColor="{StaticResource PrimaryLight}"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="0"
                            WidthRequest="44" HeightRequest="44"
                            ClipsToBounds="True">
                        <Grid>
                            <Label Text="&#xe310;" FontFamily="MaterialIcons" FontSize="24"
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Image Source="{Binding ActivePoi.LogoUrl}" Aspect="AspectFill"/>
                        </Grid>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <Label Text="{Binding ActivePoi.Title}"
                               Style="{StaticResource SectionTitle}" FontSize="14"
                               LineBreakMode="TailTruncation"/>
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="&#xe310;" FontFamily="MaterialIcons" FontSize="11"
                                   TextColor="{StaticResource Primary}" VerticalOptions="Center"/>
                            <Label Text="Đang phát" Style="{StaticResource CaptionLabel}"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                    <Border Grid.Column="2"
                            BackgroundColor="{StaticResource Primary}"
                            StrokeShape="RoundRectangle 18"
                            StrokeThickness="0"
                            WidthRequest="36" HeightRequest="36">
                        <Label Text="{Binding MiniPlayerPlayIcon}" FontFamily="MaterialIcons"
                               FontSize="20" TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMiniPlayClicked"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <Border Grid.Column="3"
                            BackgroundColor="{StaticResource Gray100}"
                            StrokeShape="RoundRectangle 18"
                            StrokeThickness="0"
                            WidthRequest="36" HeightRequest="36">
                        <Label Text="&#xe5cd;" FontFamily="MaterialIcons" FontSize="20"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMiniPlayerCloseTapped"/>
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
