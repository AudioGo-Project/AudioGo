<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             xmlns:vm="clr-namespace:AudioGo.ViewModels"
             x:Class="AudioGo_Mobile.Views.MapPage"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Background}"
             Title="Bản đồ">

    <Grid>

        <!-- ── Map Full Screen ── -->
        <Grid>
            <maps:Map x:Name="MainMap"
                      IsShowingUser="True"
                      MapType="Street"
                      IsScrollEnabled="True"
                      IsZoomEnabled="True"/>



            <!-- ── FAB: Vị trí của tôi ── -->
            <Border BackgroundColor="{StaticResource Surface}"
                    StrokeShape="RoundRectangle 24"
                    StrokeThickness="0"
                    HorizontalOptions="End"
                    VerticalOptions="Start"
                    Margin="16,40,16,16"
                    WidthRequest="48" HeightRequest="48">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.2"/>
                </Border.Shadow>
                <Label Text="&#xe55c;" FontFamily="MaterialIcons" FontSize="24" TextColor="{StaticResource Primary}"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLocateMeTapped"/>
                </Border.GestureRecognizers>
            </Border>

            <!-- ── Loading overlay ── -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>

            <!-- ── POI Banner (Anchored to center above pin) ── -->
            <Border x:Name="PoiBanner"
                    BackgroundColor="{StaticResource Surface}"
                    StrokeShape="RoundRectangle 16"
                    StrokeThickness="0"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Margin="0,0,0,160"
                    WidthRequest="220"
                    Opacity="0"
                    IsVisible="False">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.15"/>
                </Border.Shadow>
                <VerticalStackLayout Padding="14" Spacing="10">
                    <!-- Title -->
                    <Label x:Name="BannerTitle" FontAttributes="Bold" FontSize="14"
                           HorizontalTextAlignment="Center" MaxLines="2" LineBreakMode="TailTruncation" />

                    <!-- 3 Buttons Row -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <!-- Play -->
                        <Border Grid.Column="0" BackgroundColor="{StaticResource PrimaryLight}"
                                StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="0,10">
                            <Label Text="&#xe039;" FontFamily="MaterialIcons" FontSize="20" TextColor="{StaticResource Primary}" HorizontalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPoiBannerPlayClicked"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <!-- Detail -->
                        <Border Grid.Column="1" BackgroundColor="{StaticResource PrimaryLight}"
                                StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="0,10">
                            <Label Text="&#xe8f4;" FontFamily="MaterialIcons" FontSize="20" TextColor="{StaticResource Primary}" HorizontalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPoiBannerDetailClicked"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <!-- Navigate -->
                        <Border Grid.Column="2" BackgroundColor="{StaticResource PrimaryLight}"
                                StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="0,10">
                            <Label Text="&#xe52f;" FontFamily="MaterialIcons" FontSize="20" TextColor="{StaticResource Primary}" HorizontalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBannerDirectionsTapped"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>



        </Grid>
    </Grid>
</ContentPage>
