<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="AudioGo_Mobile.Views.MapPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Background}"
             Title="Bản đồ">

    <Grid RowDefinitions="*,Auto">

        <!-- ── Map Full Screen ── -->
        <Grid Grid.Row="0">
            <maps:Map x:Name="MainMap"
                      IsShowingUser="True"
                      MapType="Street"
                      IsScrollEnabled="True"
                      IsZoomEnabled="True"/>

            <!-- ── Header overlay ── -->
            <Border BackgroundColor="{StaticResource Surface}"
                    StrokeShape="RoundRectangle 0"
                    StrokeThickness="0"
                    VerticalOptions="Start"
                    Padding="20,52,20,14">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <!-- Search bar pill -->
                    <Border Grid.Column="0"
                            BackgroundColor="{StaticResource Gray100}"
                            StrokeShape="RoundRectangle 24"
                            StrokeThickness="0"
                            Padding="14,10">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                            <Label Grid.Column="0" Text="🔍" FontSize="16"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Tìm kiếm địa điểm..."
                                   Style="{StaticResource BodyLabel}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="2" Text="🎤" FontSize="16"
                                   TextColor="{StaticResource Primary}"
                                   VerticalOptions="Center"/>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSearchTapped"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <!-- Filter button -->
                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource Primary}"
                            StrokeShape="RoundRectangle 20"
                            StrokeThickness="0"
                            WidthRequest="44" HeightRequest="44">
                        <Label Text="⚙" FontSize="18" TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFilterTapped"/>
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>
            </Border>

            <!-- ── FAB: Vị trí của tôi ── -->
            <Border BackgroundColor="{StaticResource Surface}"
                    StrokeShape="RoundRectangle 24"
                    StrokeThickness="0"
                    HorizontalOptions="End"
                    VerticalOptions="End"
                    Margin="16,0,16,16"
                    WidthRequest="48" HeightRequest="48">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.2"/>
                </Border.Shadow>
                <Label Text="📍" FontSize="22"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLocateMeTapped"/>
                </Border.GestureRecognizers>
            </Border>

            <!-- ── Loading overlay ── -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
        </Grid>

        <!-- ── Bottom Sheet: Lọc / danh sách POI ── -->
        <Border Grid.Row="1"
                Style="{StaticResource MiniPlayerBar}"
                Padding="0">
            <VerticalStackLayout Spacing="0">
                <!-- Drag handle -->
                <BoxView HeightRequest="4" WidthRequest="40" Color="{StaticResource Gray300}"
                         HorizontalOptions="Center" CornerRadius="2" Margin="0,10,0,0"/>

                <!-- Category pills -->
                <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never"
                            Padding="16,12">
                    <HorizontalStackLayout Spacing="8">
                        <Border Style="{StaticResource PillBorderActive}">
                            <Label Text="🗺 Tất cả" TextColor="White" FontSize="13" FontAttributes="Bold"/>
                        </Border>
                        <Border Style="{StaticResource PillBorder}">
                            <Label Text="🦐 Hải sản" TextColor="{StaticResource TextSecondary}" FontSize="13"/>
                        </Border>
                        <Border Style="{StaticResource PillBorder}">
                            <Label Text="🍜 Bún phở" TextColor="{StaticResource TextSecondary}" FontSize="13"/>
                        </Border>
                        <Border Style="{StaticResource PillBorder}">
                            <Label Text="🍢 Ốc" TextColor="{StaticResource TextSecondary}" FontSize="13"/>
                        </Border>
                        <Border Style="{StaticResource PillBorder}">
                            <Label Text="☕ Cà phê" TextColor="{StaticResource TextSecondary}" FontSize="13"/>
                        </Border>
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- POI count -->
                <Label Margin="16,0,16,12"
                       Text="{Binding MapStatusLabel}"
                       Style="{StaticResource CaptionLabel}"/>
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>
