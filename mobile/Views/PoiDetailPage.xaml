<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AudioGo_Mobile.Views.PoiDetailPage"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Background}"
             Title="Chi tiết điểm">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- ══════════════════════════════════════════════════
                     Hero Image + Gallery Strip (Google Maps style)
                ══════════════════════════════════════════════════ -->
                <Grid HeightRequest="300">

                    <!-- Hero full image (first gallery photo) -->
                    <Image Source="{Binding HeroImageUrl}"
                           Aspect="AspectFill" />

                    <!-- Gradient overlay bottom -->
                    <BoxView VerticalOptions="End" HeightRequest="120">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#CC000000" Offset="1"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <!-- Nav icons overlay -->
                    <Grid Padding="16,52,16,16" VerticalOptions="Start"
                          ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                        <!-- Back -->
                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource SemiTransparentDark}"
                                StrokeShape="RoundRectangle 20" StrokeThickness="0"
                                WidthRequest="40" HeightRequest="40">
                            <Label Text="&#xe5c4;" FontFamily="MaterialIcons" FontSize="20" TextColor="White"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackTapped"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <!-- Favourite -->
                        <Border Grid.Column="2"
                                BackgroundColor="{StaticResource SemiTransparentDark}"
                                StrokeShape="RoundRectangle 20" StrokeThickness="0"
                                WidthRequest="40" HeightRequest="40">
                            <Label Text="&#xe87e;" FontFamily="MaterialIcons" FontSize="20" TextColor="White"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <!-- Share -->
                        <Border Grid.Column="3"
                                BackgroundColor="{StaticResource SemiTransparentDark}"
                                StrokeShape="RoundRectangle 20" StrokeThickness="0"
                                WidthRequest="40" HeightRequest="40">
                            <Label Text="&#xe80d;" FontFamily="MaterialIcons" FontSize="18" TextColor="White"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>

                    <!-- Category tag bottom-left -->
                    <Border BackgroundColor="{StaticResource Primary}"
                            StrokeShape="RoundRectangle 10" StrokeThickness="0"
                            Padding="8,4"
                            HorizontalOptions="Start" VerticalOptions="End"
                            Margin="16,0,0,12"
                            IsVisible="{Binding CategoryTag, Converter={StaticResource StringNotEmptyConverter}}">
                        <Label Text="{Binding CategoryTag}" TextColor="White"
                               FontSize="11" FontAttributes="Bold"/>
                    </Border>

                    <!-- Gallery count chip bottom-right -->
                    <Border BackgroundColor="{StaticResource SemiTransparentDark}"
                            StrokeShape="RoundRectangle 10" StrokeThickness="0"
                            Padding="8,4"
                            HorizontalOptions="End" VerticalOptions="End"
                            Margin="0,0,16,12"
                            IsVisible="{Binding HasGallery}">
                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="4">
                            <Label Grid.Column="0" Text="&#xe3b6;" FontFamily="MaterialIcons" FontSize="16" TextColor="White" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="{Binding GalleryCount}"
                                   FontSize="11" TextColor="White"
                                   VerticalOptions="Center"/>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnGalleryFullScreenTapped"/>
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

                <!-- ══════════════════════════════════════════════════
                     Google Maps-style horizontal Gallery Strip
                ══════════════════════════════════════════════════ -->
                <VerticalStackLayout IsVisible="{Binding HasGallery}"
                                     BackgroundColor="{StaticResource Surface}"
                                     Spacing="0">

                    <!-- Gallery header row -->
                    <Grid ColumnDefinitions="*,Auto" Padding="16,14,16,8">
                        <Label Grid.Column="0" Text="Ảnh" Style="{StaticResource SectionTitle}"/>
                        <Label Grid.Column="1" Text="Xem tất cả →"
                               Style="{StaticResource PrimaryLabel}"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnGalleryFullScreenTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <!-- Horizontal scrollable gallery (Google Maps review photo style) -->
                    <ScrollView Orientation="Horizontal"
                                HorizontalScrollBarVisibility="Never"
                                Padding="12,0,12,16">
                        <HorizontalStackLayout Spacing="8"
                                               BindableLayout.ItemsSource="{Binding GalleryImages}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <!-- Each photo tile -->
                                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="0"
                                            WidthRequest="130" HeightRequest="100"
                                            ClipsToBounds="True">
                                        <Image Source="{Binding .}"
                                               Aspect="AspectFill"/>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnGalleryFullScreenTapped"
                                                                  CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>

                    <BoxView HeightRequest="1" Color="{StaticResource Gray100}"/>
                </VerticalStackLayout>

                <!-- ══════════════════════════════════════════════════
                     Info Section
                ══════════════════════════════════════════════════ -->
                <VerticalStackLayout Padding="20,16,20,0" Spacing="8"
                                     BackgroundColor="{StaticResource Surface}">
                    <Label Text="{Binding Title}" Style="{StaticResource HeadlineLabel}"/>

                    <!-- Rating + Location row -->
                    <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="6">
                        <HorizontalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="&#xe838;" FontFamily="MaterialIcons" Style="{StaticResource PrimaryLabel}"/>
                            <Label Text="4.8" Style="{StaticResource PrimaryLabel}"/>
                        </HorizontalStackLayout>
                        <Label Grid.Column="1" Text="·" Style="{StaticResource BodyLabel}"/>
                        <Label Grid.Column="2" Text="Phố Vĩnh Khánh, Quận 4"
                               Style="{StaticResource BodyLabel}" VerticalOptions="Center"/>
                    </Grid>
                </VerticalStackLayout>

                <!-- ══════════════════════════════════════════════════
                     Audio Player Card
                ══════════════════════════════════════════════════ -->
                <Border Style="{StaticResource CardBorder}"
                        Margin="16,16,16,0" Padding="20">
                    <VerticalStackLayout Spacing="16">

                        <!-- Language Picker row (replaces giọng Bắc/Trung/Nam) -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Grid.Column="0" Text="&#xe894;" FontFamily="MaterialIcons" FontSize="20" TextColor="{StaticResource TextSecondary}"
                                   VerticalOptions="Center"/>
                            <Border Grid.Column="1"
                                    Style="{StaticResource InputBorder}"
                                    Padding="12,6">
                                <Picker ItemsSource="{Binding Languages}"
                                        ItemDisplayBinding="{Binding DisplayName}"
                                        SelectedItem="{Binding SelectedLanguage}"
                                        TextColor="{StaticResource TextPrimary}"
                                        FontSize="13"
                                        BackgroundColor="Transparent"
                                        Title="Chọn ngôn ngữ thuyết minh"/>
                            </Border>
                        </Grid>

                        <!-- Progress Seeker -->
                        <VerticalStackLayout Spacing="4">
                            <Slider Value="{Binding AudioProgress}"
                                    Minimum="0" Maximum="1"
                                    ThumbColor="{StaticResource Primary}"
                                    MinimumTrackColor="{StaticResource Primary}"
                                    MaximumTrackColor="{StaticResource Gray200}"
                                    DragCompleted="OnSliderDragCompleted"/>
                            <Grid ColumnDefinitions="*,*">
                                <Label Grid.Column="0" Text="{Binding CurrentTime}"
                                       Style="{StaticResource CaptionLabel}"/>
                                <Label Grid.Column="1" Text="{Binding TotalTime}"
                                       Style="{StaticResource CaptionLabel}"
                                       HorizontalOptions="End"/>
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Play controls row -->
                        <Grid ColumnDefinitions="Auto,*,Auto,*,Auto"
                              HorizontalOptions="Center">
                            <!-- Speed chip -->
                            <Border Grid.Column="0"
                                    Style="{StaticResource PillBorder}"
                                    Padding="12,6">
                                <Label Text="{Binding SpeedText}" FontSize="12"
                                       TextColor="{StaticResource TextSecondary}"
                                       FontAttributes="Bold"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSpeedTapped"/>
                                </Border.GestureRecognizers>
                            </Border>

                            <!-- Prev -->
                            <Border Grid.Column="1"
                                    StrokeShape="RoundRectangle 24" StrokeThickness="0"
                                    BackgroundColor="{StaticResource Gray100}"
                                    WidthRequest="44" HeightRequest="44"
                                    HorizontalOptions="Center">
                                <Label Text="&#xe045;" FontFamily="MaterialIcons" FontSize="20" TextColor="{StaticResource TextPrimary}"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPreviousTapped"/>
                                </Border.GestureRecognizers>
                            </Border>

                            <!-- Play/Pause big button -->
                            <Border Grid.Column="2"
                                    BackgroundColor="{StaticResource Primary}"
                                    StrokeShape="RoundRectangle 34" StrokeThickness="0"
                                    WidthRequest="64" HeightRequest="64"
                                    HorizontalOptions="Center">
                                <Border.Shadow>
                                    <Shadow Brush="{StaticResource Primary}" Offset="0,4"
                                            Radius="12" Opacity="0.4"/>
                                </Border.Shadow>
                                <Label Text="{Binding PlayPauseIcon}" FontFamily="MaterialIcons" FontSize="36" TextColor="White"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPlayPauseTapped"/>
                                </Border.GestureRecognizers>
                            </Border>

                            <!-- Next -->
                            <Border Grid.Column="3"
                                    StrokeShape="RoundRectangle 24" StrokeThickness="0"
                                    BackgroundColor="{StaticResource Gray100}"
                                    WidthRequest="44" HeightRequest="44"
                                    HorizontalOptions="Center">
                                <Label Text="&#xe044;" FontFamily="MaterialIcons" FontSize="20" TextColor="{StaticResource TextPrimary}"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnNextTapped"/>
                                </Border.GestureRecognizers>
                            </Border>

                            <!-- Repeat -->
                            <Border Grid.Column="4"
                                    Style="{StaticResource PillBorder}"
                                    Padding="12,6">
                                <Label Text="&#xe040;" FontFamily="MaterialIcons" FontSize="20" TextColor="{StaticResource TextSecondary}"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- ══════════════════════════════════════════════════
                     Description (collapsible)
                ══════════════════════════════════════════════════ -->
                <VerticalStackLayout Padding="20,16,20,0" Spacing="10"
                                     BackgroundColor="{StaticResource Surface}"
                                     Margin="0,16,0,0">
                    <Label Text="Giới thiệu" Style="{StaticResource SectionTitle}"/>
                    <Label Text="{Binding Description}"
                           Style="{StaticResource BodyLabel}"
                           MaxLines="{Binding DescExpanded, Converter={StaticResource BoolToMaxLinesConverter}}"
                           LineBreakMode="WordWrap"/>
                    <Label Style="{StaticResource PrimaryLabel}"
                           Text="{Binding ExpandLabel}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnExpandDescTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </VerticalStackLayout>

                <!-- Bottom spacer -->
                <BoxView HeightRequest="24" Color="Transparent"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ══════════════════════════════════════════════════
             Footer: Next POI button
        ══════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                BackgroundColor="{StaticResource Surface}"
                StrokeShape="RoundRectangle 0" StrokeThickness="0"
                Padding="16,12">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-2" Radius="10" Opacity="0.08"/>
            </Border.Shadow>
            <Button Text="Điểm tiếp theo →"
                    Style="{StaticResource PrimaryButton}"
                    HorizontalOptions="FillAndExpand"
                    Clicked="OnNextPoiClicked"/>
        </Border>

    </Grid>
</ContentPage>
