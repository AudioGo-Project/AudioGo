<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AudioGo_Mobile.Views.SearchPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Background}"
             Title="Tìm kiếm">

    <VerticalStackLayout Spacing="0">

        <!-- ── Search Header ── -->
        <VerticalStackLayout BackgroundColor="{StaticResource Surface}"
                             Padding="16,52,16,16"
                             Spacing="12">
            <Label Text="Khám phá Vĩnh Khánh"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}" />

            <!-- Search box -->
            <Border BackgroundColor="{StaticResource Background}"
                    Style="{StaticResource CardBorder}"
                    Padding="14,4">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Label Grid.Column="0" Text="🔍" VerticalOptions="Center"
                           FontSize="18" TextColor="{StaticResource TextSecondary}" />
                    <Entry Grid.Column="1"
                           x:Name="SearchEntry"
                           Placeholder="Tên quán, đặc sản, địa điểm..."
                           PlaceholderColor="{StaticResource TextTertiary}"
                           BackgroundColor="Transparent"
                           TextColor="{StaticResource TextPrimary}"
                           TextChanged="OnSearchTextChanged" />
                    <Label Grid.Column="2" Text="⊗"
                           VerticalOptions="Center"
                           FontSize="16"
                           TextColor="{StaticResource TextTertiary}" />
                </Grid>
            </Border>

            <!-- Category filter chips -->
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="8">
                    <Border x:Name="ChipAll" Style="{StaticResource ChipBorder}"
                            BackgroundColor="{StaticResource Primary}">
                        <Label Text="🍽️ Tất cả" TextColor="White" FontAttributes="Bold"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding FilterCommand}" CommandParameter=""/>
                        </Border.GestureRecognizers>
                    </Border>
                    <Border Style="{StaticResource ChipBorder}"
                            BackgroundColor="{StaticResource Surface}">
                        <Label Text="🦐 Hải sản" TextColor="{StaticResource TextSecondary}"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding FilterCommand}" CommandParameter="Hải sản"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <Border Style="{StaticResource ChipBorder}"
                            BackgroundColor="{StaticResource Surface}">
                        <Label Text="🍜 Bún bò" TextColor="{StaticResource TextSecondary}"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding FilterCommand}" CommandParameter="Bún bò"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <Border Style="{StaticResource ChipBorder}"
                            BackgroundColor="{StaticResource Surface}">
                        <Label Text="🍢 Ốc" TextColor="{StaticResource TextSecondary}"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding FilterCommand}" CommandParameter="Ốc"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <Border Style="{StaticResource ChipBorder}"
                            BackgroundColor="{StaticResource Surface}">
                        <Label Text="🏛️ Di tích" TextColor="{StaticResource TextSecondary}"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding FilterCommand}" CommandParameter="Di tích"/>
                        </Border.GestureRecognizers>
                    </Border>
                </HorizontalStackLayout>
            </ScrollView>
        </VerticalStackLayout>

        <!-- ── Kết quả (2-col grid) ── -->
        <ScrollView>
            <VerticalStackLayout Padding="16,16,16,40" Spacing="16">

                <!-- Loading -->
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="{StaticResource Primary}" />

                <!-- Section: Địa điểm nổi bật -->
                <Label Text="Địa điểm nổi bật"
                       Style="{StaticResource SectionTitle}"
                       IsVisible="{Binding HasResults}"/>

                <CollectionView ItemsSource="{Binding Pois}"
                                IsVisible="{Binding HasResults}"
                                ItemsLayout="VerticalGrid, 2"
                                ItemSizingStrategy="MeasureAllItems">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardBorder}"
                                    Padding="0"
                                    Margin="4,4">
                                <VerticalStackLayout Spacing="0">
                                    <Grid>
                                        <Image Source="{Binding LogoUrl}"
                                               HeightRequest="120"
                                               Aspect="AspectFill"
                                               BackgroundColor="{StaticResource Gray100}" />
                                        <!-- Save icon -->
                                        <Border HorizontalOptions="End" VerticalOptions="Start"
                                                Margin="0,8,8,0"
                                                BackgroundColor="#59FFFFFF"
                                                StrokeShape="RoundRectangle 8"
                                                StrokeThickness="0"
                                                Padding="6">
                                            <Label Text="♡" FontSize="14" TextColor="White"/>
                                        </Border>
                                    </Grid>
                                    <VerticalStackLayout Padding="10" Spacing="3">
                                        <!-- Category badge -->
                                        <Border BackgroundColor="{StaticResource PrimaryContainer}"
                                                StrokeShape="RoundRectangle 6"
                                                StrokeThickness="0"
                                                Padding="6,2"
                                                HorizontalOptions="Start">
                                            <Label Text="{Binding CategoryLabel}"
                                                   TextColor="{StaticResource Primary}"
                                                   FontSize="10"
                                                   FontAttributes="Bold" />
                                        </Border>
                                        <Label Text="{Binding Title}"
                                               Style="{StaticResource TitleLabel}"
                                               FontSize="13"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="📍 Khu phố Vĩnh Khánh"
                                               Style="{StaticResource CaptionLabel}" />
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Section: Tours -->
                <Label Text="Tours phổ biến"
                       Style="{StaticResource SectionTitle}"
                       IsVisible="{Binding HasTours}"
                       Margin="0,8,0,0"/>

                <CollectionView ItemsSource="{Binding Tours}"
                                IsVisible="{Binding HasTours}"
                                ItemsLayout="HorizontalList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardBorder}"
                                    WidthRequest="200"
                                    Padding="0"
                                    Margin="0,4,8,4">
                                <VerticalStackLayout Spacing="0">
                                    <Image Source="{Binding ThumbnailUrl}"
                                           HeightRequest="110"
                                           Aspect="AspectFill"
                                           BackgroundColor="{StaticResource Gray200}" />
                                    <VerticalStackLayout Padding="10" Spacing="4">
                                        <Label Text="{Binding Name}"
                                               Style="{StaticResource TitleLabel}"
                                               FontSize="14"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding PoiCountLabel}"
                                               Style="{StaticResource CaptionLabel}" />
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.Header>
                        <ContentView WidthRequest="0"/>
                    </CollectionView.Header>
                </CollectionView>

                <!-- Empty state -->
                <VerticalStackLayout IsVisible="{Binding IsEmpty}"
                                     HorizontalOptions="Center"
                                     Margin="0,40,0,0"
                                     Spacing="12">
                    <Label Text="🔍" FontSize="48" HorizontalOptions="Center"/>
                    <Label Text="Không tìm thấy kết quả"
                           Style="{StaticResource TitleLabel}"
                           HorizontalOptions="Center"/>
                    <Label Text="Thử tìm kiếm với từ khoá khác"
                           Style="{StaticResource BodyLabel}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </VerticalStackLayout>
</ContentPage>
