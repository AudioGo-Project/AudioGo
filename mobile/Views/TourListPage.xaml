<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AudioGo_Mobile.Views.TourListPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Background}"
             Title="Tour">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Header cố định ── -->
        <VerticalStackLayout Grid.Row="0"
                             BackgroundColor="{StaticResource Surface}"
                             Padding="16,52,16,16"
                             Spacing="12">
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="Tour khám phá"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" />
                <!-- Create tour button -->
                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource Primary}"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0"
                        Padding="12,8">
                    <Label Text="+ Tạo mới" TextColor="White"
                           FontSize="13" FontAttributes="Bold"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCreateTourClicked"/>
                    </Border.GestureRecognizers>
                </Border>
            </Grid>

            <!-- Search -->
            <Border BackgroundColor="{StaticResource Background}"
                    Style="{StaticResource CardBorder}"
                    Padding="14,4">
                <Grid ColumnDefinitions="Auto,*">
                    <Label Grid.Column="0" Text="🔍" VerticalOptions="Center"
                           FontSize="18" TextColor="{StaticResource TextSecondary}" />
                    <Entry Grid.Column="1"
                           Placeholder="Tìm kiếm tour..."
                           PlaceholderColor="{StaticResource TextTertiary}"
                           BackgroundColor="Transparent"
                           TextColor="{StaticResource TextPrimary}"
                           Text="{Binding SearchText}" />
                </Grid>
            </Border>

            <!-- Category filter chips - chủ yếu đồ ăn -->
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="8">
                    <Border Style="{StaticResource ChipBorder}"
                            BackgroundColor="{StaticResource Primary}">
                        <Label Text="🍽️ Tất cả" TextColor="White" FontAttributes="Bold"/>
                    </Border>
                    <Border Style="{StaticResource ChipBorder}"
                            BackgroundColor="{StaticResource Surface}">
                        <Label Text="🦐 Hải sản" TextColor="{StaticResource TextSecondary}"/>
                    </Border>
                    <Border Style="{StaticResource ChipBorder}"
                            BackgroundColor="{StaticResource Surface}">
                        <Label Text="🍜 Bún bò" TextColor="{StaticResource TextSecondary}"/>
                    </Border>
                    <Border Style="{StaticResource ChipBorder}"
                            BackgroundColor="{StaticResource Surface}">
                        <Label Text="🍢 Ốc" TextColor="{StaticResource TextSecondary}"/>
                    </Border>
                    <Border Style="{StaticResource ChipBorder}"
                            BackgroundColor="{StaticResource Surface}">
                        <Label Text="☕ Cà phê" TextColor="{StaticResource TextSecondary}"/>
                    </Border>
                    <Border Style="{StaticResource ChipBorder}"
                            BackgroundColor="{StaticResource Surface}">
                        <Label Text="🏛️ Di tích" TextColor="{StaticResource TextSecondary}"/>
                    </Border>
                </HorizontalStackLayout>
            </ScrollView>
        </VerticalStackLayout>

        <!-- ── Tour list ── -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Tours}"
                        SelectionMode="None">
            <CollectionView.Header>
                <VerticalStackLayout>
                    <ActivityIndicator IsRunning="{Binding IsLoading}"
                                       IsVisible="{Binding IsLoading}"
                                       Color="{StaticResource Primary}"
                                       Margin="0,16"/>
                    <Label Text="{Binding CountLabel}"
                           Style="{StaticResource BodyLabel}"
                           Margin="16,8,16,0"
                           IsVisible="{Binding HasTours}"/>
                </VerticalStackLayout>
            </CollectionView.Header>
            <CollectionView.Footer>
                <ContentView HeightRequest="40"/>
            </CollectionView.Footer>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorder}"
                            Padding="0"
                            Margin="16,4,16,4">
                        <VerticalStackLayout>
                            <Grid HeightRequest="160">
                                <Image Source="{Binding ThumbnailUrl}"
                                       Aspect="AspectFill"
                                       BackgroundColor="{StaticResource Gray200}" />
                                <BoxView BackgroundColor="#50000000" />
                                <Border Style="{StaticResource ChipBorder}"
                                        HorizontalOptions="Start"
                                        VerticalOptions="Start"
                                        Margin="12"
                                        BackgroundColor="{StaticResource Primary}">
                                    <Label Text="★ Phổ biến" TextColor="White"
                                           FontSize="11" FontAttributes="Bold"/>
                                </Border>
                            </Grid>
                            <VerticalStackLayout Padding="16" Spacing="8">
                                <Label Text="{Binding Name}"
                                       Style="{StaticResource TitleLabel}" />
                                <Label Text="{Binding Description}"
                                       Style="{StaticResource BodyLabel}"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2"/>
                                <Grid ColumnDefinitions="Auto,Auto,*" Margin="0,4,0,0">
                                    <Label Grid.Column="0"
                                           Text="{Binding PoiCountLabel}"
                                           Style="{StaticResource CaptionLabel}"
                                           Margin="0,0,16,0"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding CreatedAtLabel}"
                                           Style="{StaticResource CaptionLabel}"/>
                                    <Label Grid.Column="2"
                                           Text="Miễn phí"
                                           TextColor="{StaticResource Primary}"
                                           FontAttributes="Bold"
                                           HorizontalOptions="End"/>
                                </Grid>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenTourCommand}"
                                                  CommandParameter="{Binding TourId}"/>
                        </Border.GestureRecognizers>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
