<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AudioGo_Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:AudioGo_Mobile.Views"
    Title="AudioGo">

    <!-- ── Bottom Tab Bar ── -->
    <TabBar>
        <ShellContent
            Title="Trang chủ"
            Icon="home.png"
            ContentTemplate="{DataTemplate views:MainPage}"
            Route="Home" />

        <ShellContent
            Title="Bản đồ"
            Icon="map.png"
            ContentTemplate="{DataTemplate views:MapPage}"
            Route="Map" />

        <ShellContent
            Title="Tour"
            Icon="tour.png"
            ContentTemplate="{DataTemplate views:TourListPage}"
            Route="TourList" />

        <ShellContent
            Title="Khám phá"
            Icon="search.png"
            ContentTemplate="{DataTemplate views:SearchPage}"
            Route="Search" />
    </TabBar>

    <!-- ── Modal / Push Routes (không phải tab) ── -->
    <Shell.Resources>
        <ResourceDictionary/>
    </Shell.Resources>

</Shell>
