<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AudioGo_Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:AudioGo_Mobile.Views"
    Title="AudioGo">

    <TabBar>
        <!-- Tab Bản đồ -->
        <ShellContent
            Title="Bản đồ"
            Icon="map.png"
            ContentTemplate="{DataTemplate views:MapPage}"
            Route="MapPage" />

        <!-- Tab Trang chủ -->
        <ShellContent
            Title="Trang chủ"
            Icon="home.png"
            ContentTemplate="{DataTemplate views:MainPage}"
            Route="MainPage" />
    </TabBar>

</Shell>
