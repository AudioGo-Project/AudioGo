<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AudioGo_Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:AudioGo_Mobile.Views"
    Title="AudioGo">

    <TabBar>
        <ShellContent
            Title="Trang chủ"
            Icon="home.png"
            ContentTemplate="{DataTemplate views:MainPage}"
            Route="MainPage" />

        <ShellContent
            Title="Bản đồ"
            Icon="map.png"
            ContentTemplate="{DataTemplate views:MapPage}"
            Route="MapPage" />

        <ShellContent
            Title="Tour"
            Icon="tour.png"
            ContentTemplate="{DataTemplate views:TourListPage}"
            Route="TourListPage" />

        <ShellContent
            Title="Tìm kiếm"
            Icon="search.png"
            ContentTemplate="{DataTemplate views:SearchPage}"
            Route="SearchPage" />
    </TabBar>

    <!-- Routes chỉ dùng để navigation (không phải tab) -->
    <Shell.Resources>
        <ResourceDictionary />
    </Shell.Resources>

</Shell>
