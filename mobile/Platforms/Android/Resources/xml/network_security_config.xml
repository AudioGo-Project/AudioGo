<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext (HTTP) traffic để test locally -->
    <!-- Ưu tiên HTTPS trên production, nhưng dev có thể cần HTTP cho localhost/192.168.x.x -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Localhost + emulator testing -->
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <!-- Local WiFi network (adjust per your setup) -->
        <domain includeSubdomains="true">192.168.0.0/16</domain>
    </domain-config>
    <!-- All other domains require HTTPS (recommended for production) -->
</network-security-config>
