<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        ⚠️ DEV ONLY — cho phép HTTP cleartext tới server dev trên LAN
        Android 9+ (API 28+) block HTTP theo mặc định.
        CIDR notation (192.168.0.0/16) KHÔNG được Android hỗ trợ trong <domain> tag
        → phải liệt kê IP cụ thể.
        Trước khi release production: xóa khối này và chuyển sang HTTPS.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Android Emulator: 10.0.2.2 = host machine localhost -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <!-- Máy dev trên LAN WiFi — cập nhật IP nếu thay đổi -->
        <domain includeSubdomains="false">192.168.1.12</domain>
    </domain-config>
</network-security-config>
