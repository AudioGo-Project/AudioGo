# Azure API Keys — Template
# KHÔNG commit file này lên git (đã có trong .gitignore)
# Sao chép file này thành .env và điền key thật vào

# ── JWT ──────────────────────────────────────────────────────
# Tạo ngẫu nhiên tối thiểu 32 ký tự
# Gợi ý: https://generate-random.org/string-generator
Jwt__Key=

# ── Azure Blob Storage ───────────────────────────────────────
# Azure Portal → Storage Account → Access Keys → Connection String
Azure__BlobStorage__ConnectionString=

# ── Azure Translator ─────────────────────────────────────────
# Azure Portal → Translator → Keys and Endpoint → KEY 1
Azure__Translator__Key=

# ── Azure Cognitive Speech (TTS) ─────────────────────────────
# Azure Portal → Speech Service → Keys and Endpoint → KEY 1
Azure__Speech__Key=
